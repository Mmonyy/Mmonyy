function isPalindroma($stringa) {
    $stringa = strtolower(str_replace(' ', '', $stringa));

    $lunghezza = strlen($stringa);

    for ($i = 0; $i < $lunghezza / 2; $i++) {
        if ($stringa[$i] != $stringa[$lunghezza - 1 - $i]) {
            return false;
        }
    }

    return true;
}

$parola1 = "Anna";
$parola2 = "ciao";

echo "$parola1 → ";
echo isPalindroma($parola1) ? "true" : "false";
echo "<br>";

echo "$parola2 → ";
echo isPalindroma($parola2) ? "true" : "false";
