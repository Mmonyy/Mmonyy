function IsMultiplo($a, $b) {
    if ($b == 0) {
        return false;
    }
    return ($a % $b == 0);
}

if (isset($_GET['btn_multiplo'])) {

    $N1 = intval($_GET['Numero1']);
    $N2 = intval($_GET['Numero2']);

    if (IsMultiplo($N1, $N2)) {
        echo "Il numero è multiplo";
    } else {
        echo "Il numero NON è multiplo";
    }

} else {
    echo "Invia il form per vedere il risultato (GET)";
